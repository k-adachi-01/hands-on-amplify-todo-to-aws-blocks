# コピーして .env.local として使う（.env.local は gitignore 済み）
# cp .env.local.example .env.local

# 通常は不要: デフォルトプロファイルで aws login しただけなら設定しなくてよい
#
# 名前付きプロファイルで aws login --profile my-sandbox する場合だけ、
# 次の行のコメントを外してプロファイル名を合わせる:
# AWS_PROFILE=my-sandbox

# 任意: リージョン（aws configure で設定済みなら不要）
# AWS_REGION=ap-northeast-1
